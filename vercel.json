{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/star",
      "destination": "/api/star.ts"
    },
    {
      "source": "/api/essay",
      "destination": "/api/essay.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
